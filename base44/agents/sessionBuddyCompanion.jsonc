      "description": "Returns user details: {userId, full_name, email, firstName, preferredTone, tolerance}"
    },
    {
      "function_name": "getUserStats",
      "description": "Returns comprehensive usage statistics"
    }
  ],
  "whatsapp_greeting": "Hey there! \ud83c\udf3f I'm your Session Buddy AI wingman on WhatsApp. Ready to track smart, stay safe, and plan your perfect sessions? What's up?"
